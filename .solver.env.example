# Local TexasSolver backend config.
#
# Copy this file to .solver.env, then edit the two paths below.
# .solver.env is ignored by git because these paths are machine-local.

# Native TexasSolver release:
TENGAN_SOLVER_BIN=/path/to/TexasSolver/console_solver
TENGAN_SOLVER_CWD=/path/to/TexasSolver

# Optional. The extension currently expects the default 7333 port.
# TENGAN_SOLVER_PORT=7333

# WASM backend alternative after running: bash wasm/build-wasm.sh
# TENGAN_SOLVER_BIN=~/TexasSolver-wasm-src/build-wasm/console_solver.js
# TENGAN_SOLVER_CWD=~/TexasSolver-wasm-src
